# ─── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
*.egg
.eggs/

# Dev tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.ipynb_checkpoints/

# Coverage
.coverage
.coverage.*
htmlcov/
*.cover

# Python build / dist
build/
dist/
wheels/

# ─── Environment / secrets ────────────────────────────────
.env
.env.*
!.env.example
.envrc

# ─── Data files ───────────────────────────────────────────
# Bulk data and generated outputs are excluded by default — most contain
# PII (emails, tokens) or are too large to belong in git. Add explicit
# allowlist entries for any pipeline-config file that should be committed.
*.csv
*.xlsx
*.xml
*.parquet
*.tsv
*.jsonl
!pipeline/incumbent_overrides.csv

# Pipeline-output directories.
pipeline/out/
pipeline/output/

# Office lock files (Excel/Word holds these while a file is open).
~$*

# ─── Logs ─────────────────────────────────────────────────
*.log
logs/

# ─── OS ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editors / IDE ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursorignore

# ─── Claude Code ─────────────────────────────────────────
# Local user overrides — per-user settings shouldn't leak.
# Keep .claude/launch.json (shared debug config) committed.
.claude/settings.local.json
.claude/*.local.json
# Per-session worktrees Claude Code creates for isolated agents — local only.
.claude/worktrees/
